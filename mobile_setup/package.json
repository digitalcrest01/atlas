{
  "name": "myatlastic",
  "version": "1.0.0",
  "description": "Myatlastic — interactive geography app",
  "private": true,
  "scripts": {
    "sync": "npx cap sync",
    "open:ios": "npx cap open ios",
    "open:android": "npx cap open android",
    "add:ios": "npx cap add ios",
    "add:android": "npx cap add android",
    "build": "echo 'Static site — no build step. Run: npx cap sync.'",
    "serve": "cd ../web && python3 -m http.server 8000"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.1",
    "@capacitor/core": "^6.1.2",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/preferences": "^6.0.2",
    "@capacitor/splash-screen": "^6.0.2",
    "@capacitor/status-bar": "^6.0.1",
    "@revenuecat/purchases-capacitor": "^9.2.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2"
  }
}
